{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Formulaire",
  "version": "0.1.0",
  "identifier": "com.walidroid.formbuilder",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "trunk serve",
    "beforeBuildCommand": "trunk build --release"
  },
  "app": {
    "windows": [
      {
        "title": "FormBuilder",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "walid jadla",
    "copyright": "free",
    "shortDescription": "google forms simulator",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
